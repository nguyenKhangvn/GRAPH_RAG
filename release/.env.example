# =============================================================================
#  Vietnamese Tourism GraphRAG — Environment Configuration
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# =============================================================================

# ── NEO4J DATABASE ───────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ── LLM PROVIDERS (at least one required) ────────────────────────────────────
# DeepSeek (recommended — primary LLM)
#DEEPSEEK_API_KEY=sk-your_deepseek_key
#DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Groq (free tier available, good fallback)
#GROQ_API_KEY=gsk_your_groq_key

# Gemini
#GEMINI_API_KEY=your_gemini_key

# OpenAI
#OPENAI_API_KEY=sk-your_openai_key

# XAI (Grok)
#XAI_API_KEY=your_xai_key

# XiaoMiMo (Mimo)
#MIMO_API_KEY=your_mimo_key
#MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# ── LLM MODEL SELECTION ──────────────────────────────────────────────────────
LLM_MODEL_NAME=deepseek-chat

# Optional: use a different model for pipeline vs query analyzer
#PIPELINE_LLM_MODEL_NAME=deepseek-chat
#QUERY_ANALYZER_LLM_MODEL_NAME=deepseek-chat

# Fallback models (comma-separated, requires ENABLE_LLM_FALLBACKS=true)
#LLM_FALLBACK_MODELS=groq/llama-3.1-70b,gemini/gemini-2.0-flash
#ENABLE_LLM_FALLBACKS=false

# ── EMBEDDING MODEL ──────────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
TOP_K=10

# ── FEATURE FLAGS ────────────────────────────────────────────────────────────
ENABLE_AGENTIC_RETRIEVAL=true
AGENTIC_MAX_ITERATIONS=2
AGENTIC_MAX_SUB_QUERIES=3

ENABLE_TEXT_TO_CYPHER=true
TEXT_TO_CYPHER_MAX_RESULTS=20
TEXT_TO_CYPHER_TIMEOUT_MS=5000

ENABLE_EXPANDED_NAMES_IN_SEARCH_QUERY=false
MAX_EXPANDED_GROUNDED_NAMES=3

CONTEXT_BUILDER_VERSION=v1
ENABLE_CONTEXT_ORGANIZER=false
ENABLE_STRUCTURAL_CONTEXT=true
ENABLE_HARD_KEEP_1HOP=true
ENABLE_TEXTUAL_MMR=true
ENABLE_CROSS_ENCODER_RERANKER=false
#CROSS_ENCODER_RERANKER_MODEL=BAAI/bge-reranker-base

ENABLE_BGE_CANDIDATE_SCORING=false
#BGE_CANDIDATE_SCORING_MODEL=BAAI/bge-reranker-base

ENABLE_COMMUNITY_SUMMARY=false

ENABLE_QUERY_FRAME_V2=false
ENABLE_ROLE_AWARE_GROUNDING=false
QUERY_FRAME_MIN_CONFIDENCE=0.60

WEB_SEARCH_ENABLED=false
#WEB_SEARCH_API_KEY=your_tavily_key
WEB_SEARCH_PROVIDER=duckduckgo

GRAPH_RAG_V3_ENABLED=false
GRAPH_RAG_V3_MAX_FACTS_PER_ANCHOR=18

FREEZE_METADATA_AFTER_STEP1=true
DEBUG=True

# ── CONTEXT LIMITS ───────────────────────────────────────────────────────────
RAW_CONTEXT_DEFAULT_MAX_ITEMS=40
#RAW_CONTEXT_MAX_ITEMS_TOUR_PLAN=40
#RAW_CONTEXT_MAX_ITEMS_DISCOVERY=60
#RAW_CONTEXT_MAX_ITEMS_TOURISM=40
#RAW_CONTEXT_MAX_ITEMS_FOOD=40
#RAW_CONTEXT_MAX_ITEMS_ACCOMMODATION=40
#RAW_CONTEXT_MAX_ITEMS_EVENT=40
#RAW_CONTEXT_MAX_ITEMS_ENTITY_FACT=40
#RAW_CONTEXT_MAX_ITEMS_DISTANCE=40

# ── VECTOR INDEXES (comma-separated, overrides default list) ─────────────────
#VECTOR_INDEXES_STR=accommodation_vec_idx,dish_vec_idx,event_vec_idx,restaurant_vec_idx,tour_vec_idx,tourist_vec_idx
